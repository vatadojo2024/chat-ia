# Config do serviço do Chat IA. Copie para .env e preencha.
# NENHUM segredo no código — tudo vem daqui. O .env NÃO vai para o git nem para a imagem.

# ── Supabase (obrigatórias) ───────────────────────────────────────────────────
SUPABASE_URL="https://SEU-PROJETO.supabase.co"
SUPABASE_KEY="service_role_secret_aqui"     # service_role; usada só para LER users.role

# ── IA (obrigatória p/ o chat responder) ──────────────────────────────────────
ANTHROPIC_API_KEY="sk-ant-..."              # sem ela, a resposta da IA vira status 'erro'

# ── Clint (CRM, só leitura) ───────────────────────────────────────────────────
# Sem CLINT_TOKEN, as tools de CRM retornam mensagem tratável (a IA explica sem quebrar).
CLINT_TOKEN="..."                           # token do Clint; o servidor o adiciona no header
CLINT_TOKEN_HEADER="api-token"              # nome do header de auth do Clint (default api-token)

# ── Redis (opcional) — liga buscar_conversa do closer ─────────────────────────
# Sem REDIS_URL, a ferramenta nem é registrada e o closer roda normalmente.
# Na VPS: redis://redis:6379 (sem senha, host interno do Docker — só resolve na VPS).
# Suporta rediss:// (TLS). O DB dos closers vem de REDIS_CLOSERS_DB, não do /0 da URL.
REDIS_URL="redis://redis:6379"
REDIS_CLOSERS_DB="8"                        # banco dos closers (a URL pode terminar em /0)

# ── CORS — origens do front liberadas a chamar o serviço ──────────────────────
# Lista explícita (produção, ex.: Vercel). Nunca "*" com credenciais.
CORS_ORIGINS="http://localhost:3000,http://127.0.0.1:3000,https://seu-front.vercel.app"
# Regex que libera qualquer porta de localhost/127.0.0.1 em dev (Next 3000, 3001, ...).
CORS_ORIGIN_REGEX="http://(localhost|127\\.0\\.0\\.1)(:\\d+)?"

# ── Opcionais (têm default no código) ─────────────────────────────────────────
# CHAT_MODEL="claude-sonnet-4-6"            # modelo do chat (default claude-sonnet-4-6)
# PLAYBOOK_MODEL="claude-opus-4-8"          # modelo Opus do gerador de playbook (NÃO use opus-4-7)
# HISTORY_LIMIT="20"                        # qtd de mensagens de histórico enviadas à IA
# AGENT_MAX_ITERS="6"                       # máximo de rodadas de ferramenta do agente
# SUPABASE_JWT_SECRET=""                    # só se o projeto usar HS256 (este é ES256/JWKS)
# AUTH_AUDIENCE="authenticated"             # aud esperado no token (default authenticated)
# PORT="8000"                               # porta do uvicorn (default 8000)
